#!/bin/sh
# shellcheck source=/dev/null

INIT_DIR="/opt/muos/script/init"
ASYNC_DIR="$INIT_DIR/async"

run_stop_script() {
	S="$1"

	[ -e "$S" ] || return 0
	[ -f "$S" ] || return 0

	case "$S" in
		*.sh)
			(
				trap - INT QUIT TSTP
				set stop
				. "$S"
			)
			;;
		*)
			"$S" stop
			;;
	esac
}

reverse_run_dir() {
	DIR="$1"

	[ -d "$DIR" ] || return 0

	for S in $(printf '%s\n' "$DIR"/S??* | sort -r); do
		[ -e "$S" ] || continue
		run_stop_script "$S"
	done
}

# Stop async services first
reverse_run_dir "$ASYNC_DIR"

# Then stop normal init scripts
reverse_run_dir "$INIT_DIR"

exit 0
